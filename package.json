{
  "name": "featish",
  "version": "0.1.0",
  "description": "CLI tool to scaffold feature modules with a consistent structure",
  "type": "module",
  "bin": {
    "featish": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "bun test",
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "cli",
    "scaffold",
    "feature",
    "generator"
  ],
  "author": "Utkarsh Priyadarshi (https://github.com/utkarsh5026)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/utkarsh5026/featish.git"
  },
  "homepage": "https://github.com/utkarsh5026/featish#readme",
  "bugs": {
    "url": "https://github.com/utkarsh5026/featish/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "chalk": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
